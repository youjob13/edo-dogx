{
  "name": "edo",
  "private": true,
  "version": "0.0.1",
  "description": "Электронный документооборот — monorepo",
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/commit-msg",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:gateway": "pnpm --filter gateway dev",
    "build:all": "pnpm -r build",
    "lint:all": "pnpm -r lint",
    "test:all": "pnpm -r test",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:health": "docker compose ps && docker compose exec gateway curl -f http://localhost:3000/api/health",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v && docker system prune -f",
    "db:migrate": "docker compose exec document-service ./migrate.sh",
    "db:backup": "docker compose exec postgres pg_dump -U edo_user -d edo > backup_$(date +%Y%m%d_%H%M%S).sql",
    "deploy:staging": "docker compose -f docker-compose.staging.yml up -d --build",
    "deploy:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "health:check": "curl -f http://localhost:3000/api/health && curl -f http://localhost:4000 && echo 'All services healthy'"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-angular": "^19.0.0"
  }
}
