{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "build:ru": "ng build --configuration=ru",
    "build:en": "ng build --configuration=en",
    "build:ssr": "ng build --configuration=production",
    "extract-i18n": "ng extract-i18n --format=xlf2 --output-path src/locale",
    "serve:ssr": "node dist/frontend/server/server.mjs",
    "serve:ru": "ng serve --configuration=ru",
    "serve:en": "ng serve --configuration=en",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "editor:check": "node -e \"console.log('editor deps ready')\"",
    "export:check": "node -e \"console.log('export deps ready')\"",
    "test": "ng test --watch=false"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/localize": "^21.2.9",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@edo/ts-types": "workspace:*",
    "@ng-web-apis/universal": "^5.2.0",
    "@taiga-ui/addon-mobile": "^5.2.0",
    "@taiga-ui/addon-table": "^5.2.0",
    "@taiga-ui/cdk": "^5.2.0",
    "@taiga-ui/core": "^5.2.0",
    "@taiga-ui/icons": "^5.2.0",
    "@taiga-ui/kit": "^5.2.0",
    "@taiga-ui/layout": "^5.2.0",
    "@taiga-ui/styles": "^5.2.0",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "express": "^4.18.0",
    "http-proxy-middleware": "^3.0.5",
    "ngx-tiptap": "^14.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
