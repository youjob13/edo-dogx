# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edo
POSTGRES_USER=edo_user
POSTGRES_PASSWORD=change_me

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=edo
KEYCLOAK_CLIENT_ID=edo-gateway
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_PASSWORD=change_me

# ── API Gateway (BFF) ────────────────────────────────────────────────
GATEWAY_PORT=3000
SESSION_SECRET=change_me_32_chars_minimum_secret

# ── Frontend (SSR) ───────────────────────────────────────────────────
FRONTEND_PORT=4000
API_BASE_URL=http://gateway:3000
