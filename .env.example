# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edo
POSTGRES_USER=edo_user
POSTGRES_PASSWORD=change_me

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=edo
KEYCLOAK_CLIENT_ID=edo-gateway
KEYCLOAK_CLIENT_SECRET=change_me
KEYCLOAK_ADMIN_PASSWORD=change_me
# OAuth2 redirect URI (BFF receives the authorization code here)
KEYCLOAK_REDIRECT_URI=http://localhost:4000/api/auth/callback
# Where to redirect after Keycloak logout
KEYCLOAK_POST_LOGOUT_REDIRECT_URI=http://localhost:4000

# ── API Gateway (BFF) ────────────────────────────────────────────────
GATEWAY_PORT=3000
SESSION_SECRET=s3cr3t!ExAmPlE-32-chArS-mInImUm!!
# Set to true only when serving over HTTPS
COOKIE_SECURE=false

# ── Document Export ───────────────────────────────────────────────────
DOCUMENT_EXPORT_TIMEOUT_SECONDS=10
DOCUMENT_EXPORT_MAX_CONTENT_BYTES=2097152
DOCUMENT_EXPORT_MAX_RETRIES=2

# ── MinIO (S3-compatible storage for export artifacts) ───────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=edo-exports
MINIO_USE_SSL=false
MINIO_PRESIGNED_EXPIRY_SECONDS=900

# ── Frontend (SSR) ───────────────────────────────────────────────────
FRONTEND_PORT=4000
# Used by the SSR server to proxy /api/* to the BFF.
# Local dev: http://localhost:3000
# Docker: overridden in docker-compose.yml to http://gateway:3000 automatically.
API_BASE_URL=http://localhost:3000
